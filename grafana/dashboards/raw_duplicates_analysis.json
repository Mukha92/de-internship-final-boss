        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "PDEE91DDB90597936"
          },
          "queryType": "sql",
          "rawSql": "SELECT * FROM (SELECT 'stores' as table, count() as duplicates FROM (SELECT store_id FROM raw.stores GROUP BY store_id HAVING count() > 1) UNION ALL SELECT 'products', count() FROM (SELECT id FROM raw.products GROUP BY id HAVING count() > 1) UNION ALL SELECT 'customers', count() FROM (SELECT customer_id FROM raw.customers GROUP BY customer_id HAVING count() > 1) UNION ALL SELECT 'purchases', count() FROM (SELECT purchase_id FROM raw.purchases GROUP BY purchase_id HAVING count() > 1)) ORDER BY duplicates DESC;",
          "refId": "A"
        }
      ],
      "title": "📊 Duplicates per Table (Bar)",
      "type": "barchart"
