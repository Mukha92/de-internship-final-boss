          "rawSql": "SELECT * FROM (SELECT 'dim_manufacturer' as table, count() as total_records, count(DISTINCT manufacturer_sk) as unique_keys, count() - count(DISTINCT manufacturer_sk) as duplicate_keys, round((count() - count(DISTINCT manufacturer_sk)) * 100.0 / count(), 2) as duplicate_percent FROM mart.dim_manufacturer UNION ALL SELECT 'dim_store_location', count(), count(DISTINCT store_location_sk), count() - count(DISTINCT store_location_sk), round((count() - count(DISTINCT store_location_sk)) * 100.0 / count(), 2) FROM mart.dim_store_location UNION ALL SELECT 'dim_delivery_address', count(), count(DISTINCT delivery_address_sk), count() - count(DISTINCT delivery_address_sk), round((count() - count(DISTINCT delivery_address_sk)) * 100.0 / count(), 2) FROM mart.dim_delivery_address UNION ALL SELECT 'dim_product', count(), count(DISTINCT product_sk), count() - count(DISTINCT product_sk), round((count() - count(DISTINCT product_sk)) * 100.0 / count(), 2) FROM mart.dim_product UNION ALL SELECT 'dim_customer', count(), count(DISTINCT customer_sk), count() - count(DISTINCT customer_sk), round((count() - count(DISTINCT customer_sk)) * 100.0 / count(), 2) FROM mart.dim_customer UNION ALL SELECT 'dim_store', count(), count(DISTINCT store_sk), count() - count(DISTINCT store_sk), round((count() - count(DISTINCT store_sk)) * 100.0 / count(), 2) FROM mart.dim_store UNION ALL SELECT 'dim_date', count(), count(DISTINCT date_sk), count() - count(DISTINCT date_sk), round((count() - count(DISTINCT date_sk)) * 100.0 / count(), 2) FROM mart.dim_date UNION ALL SELECT 'fact_purchases', count(), count(DISTINCT purchase_id), count() - count(DISTINCT purchase_id), round((count() - count(DISTINCT purchase_id)) * 100.0 / count(), 2) FROM mart.fact_purchases UNION ALL SELECT 'fact_purchase_items', count(), count(DISTINCT fact_sk), count() - count(DISTINCT fact_sk), round((count() - count(DISTINCT fact_sk)) * 100.0 / count(), 2) FROM mart.fact_purchase_items) ORDER BY duplicate_percent D